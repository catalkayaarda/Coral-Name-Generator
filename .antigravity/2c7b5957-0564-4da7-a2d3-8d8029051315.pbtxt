          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                  className=\"flex items-center justify-center gap-2 bg-natural-accent hover:bg-natural-accent/90 text-white font-bold px-8 py-3.5 rounded-full disabled:opacity-50 disabled:cursor-not-allowed transition-all shadow-md shadow-natural-accent/25 cursor-pointer\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
