ct\n                            value={coral.lighting}\n                            onChange={(e) => updateCoralField(coral.id, \"lighting\", e.target.value)}\n                            className=\"w-full bg-natural-panel border border-natural-border hover:border-natural-muted focus:border-natural-teal focus:bg-white rounded-xl px-3 py-2.5 text-xs text-natural-text outline-none transition-all cursor-pointer shadow-2xs font-semibold\"\n                          >\n                            <option value=\"Low\">Low</option>\n                            <option value=\"Medium\">Medium</option>\n                            <option value=\"High\">High</option>\n                          </select>\n                        </div>\n\n                        <div>\n                          <label className=\"block text-xs font-bold text-natural-muted mb-1.5 uppercase tracking-widest flex items-center gap-1\">\n                            <Wind className=\"w-3.5 h-3.5 text-natural-teal\" />\n                            Water Flow\n                          </label>\n                          <select\n                            value={coral.waterFlow}\n                            onChange={(e) => updateCoralField(coral.id, \"waterFlow\", e.target.value)}\n                            className=\"w-full bg-natural-panel border border-natural-border hover:border-natural-muted focus:border-natural-teal focus:bg-white rounded-xl px-3 py-2.5 text-xs text-natural-text outline-none transition-all cursor-pointer shadow-2xs font-semibold\"\n                          >\n                            <option value=\"Low\">Low</option>\n                            <option value=\"Medium\">Medium</option>\n                            <option value=\"High\">High</option>\n                          </select>\n                        </div>\n\n                        <div>\n                          <label className=\"block text-xs font-bold text-natural-muted mb-1.5 uppercase tracking-wi