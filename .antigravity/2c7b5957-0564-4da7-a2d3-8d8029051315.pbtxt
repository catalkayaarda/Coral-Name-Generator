  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "// 1. API: Generate Coral Names & Metadata from Photos\napp.post(\"/api/generate-coral-names\", async (req, res) => {\n  try {\n    const { images } = req.body as {\n      images: Array<{ id: string; base64: string; type: string; name: string }>;\n    };\n\n    if (!images || images.length === 0) {\n      return res.status(400).json({ error: \"No images provided.\" });\n    }\n\n    const ai = getGeminiClient();\n\n    // Analyze images concurrently for maximum speed and performance\n    const analysisPromises = images.map(async (img) => {\n      try {\n        // Strip out the data url prefix if it\'s there\n        const base64Data = img.base64.replace(/^data:image\\/\\w+;base64,/, \"\");\n\n        const prompt = \"Analyze this coral photo. Determine a beautiful, catchy trade name for it \" +\n          \"(e.g., \'Dragon Soul Torch\', \'Sunset Montipora\', \'Neon Green Star Polyps\', \'Space Invader Pectinia\') \" +\n          \"and find its correct scientific name (at least the Genus level, species if identifiable). \" +\n          \"Provide care parameters including care level, lighting, flow, placement, and a vivid visual description.\";\n\n        const response = await ai.models.generateContent({\n          model: \"gemini-3.5-flash\",\n          contents: [\n            {\n              inlineData: {\n                data: base64Data,\n                mimeType: img.type || \"image/jpeg\",\n              },\n            },\n            {\n              text: prompt,\n            },\n          ],\n          config: {\n            responseMimeType: \"application/json\",\n            responseSchema: {\n              type: Type.OBJECT,\n              properties: {\n                commonName: {\n                  type: Type.STRING,\n                  description: \"Creative, appealing, and colorful aquarium trade name (e.g. \'Rasta Zoanthid\').\",\n                },\n                scientificName: {\n                  type: Type.STRING,\n                  description: \"Scientific Genus and species name (e.g. \'Zoanthus sp.\').\",\n                },\n                careLevel: {\n                  type: Type.STRING,\n                  description: \"Aquarium care difficulty: Easy, Moderate, or Difficult.\",\n                },\n                lighting: {\n                  type: Type.STRING,\n                  description: \"Lighting intensity required: Low, Medium, or High.\",\n                },\n                waterFlow: {\n                  type: Type.STRING,\n                  description: \"Water movement/flow rate required: Low, Medium, or High.\",\n                },\n                placement: {\n                  type: Type.STRING,\n                  description: \"Recommended coral position in the tank (e.g., Low rockwork, Sandbed, Top reef, Any).\",\n                },\n                description: {\n                  type: Type.STRING,\n                  description: \"Vivid, attractive description highlighting the colors, textures, and growth form.\",\n                },\n              },\n              required: [\n                \"commonName\",\n                \"scientificName\",\n                \"careLevel\",\n                \"lighting\",\n                \"waterFlow\",\n                \"placement\",\n                \"description\",\n              ],\n            },\n          },\n        });"
      replacement_content: "// Helper: Retry operation with exponential backoff for transient API errors (e.g., 503, 429)\nasync function retryWithBackoff<T>(\n  fn: () => Promise<T>,\n  retries = 3,\n  delay = 1500\n): Promise<T> {\n  try {\n    return await fn();\n  } catch (error: any) {\n    if (retries <= 0) {\n      throw error;\n    }\n    const errorStr = String(error.message || \"\") + \" \" + String(error.status || \"\") + \" \" + JSON.stringify(error);\n    const isTransient =\n      error.status === 429 ||\n      error.status === 503 ||\n      errorStr.includes(\"503\") ||\n      errorStr.includes(\"429\") ||\n      errorStr.includes(\"UNAVAILABLE\") ||\n      errorStr.includes(\"Resource has been exhausted\") ||\n      errorStr.includes(\"high demand\") ||\n      errorStr.includes(\"temporarily\");\n\n    if (isTransient) {\n      console.warn(`Gemini API experienced a transient issue. Retrying in ${delay}ms... (Attempts remaining: ${retries})`);\n      await new Promise((resolve) => setTimeout(resolve, delay));\n      return retryWithBackoff(fn, retries - 1, delay * 2);\n    }\n    throw error;\n  }\n}\n\n// 1. API: Generate Coral Names & Metadata from Photos\napp.post(\"/api/generate-coral-names\", async (req, res) => {\n  try {\n    const { images } = req.body as {\n      images: Array<{ id: string; base64: string; type: string; name: string }>;\n    };\n\n    if (!images || images.length === 0) {\n      return res.status(400).json({ error: \"No images provided.\" });\n    }\n\n    const ai = getGeminiClient();\n\n    // Analyze images concurrently for maximum speed and performance\n    const analysisPromises = images.map(async (img) => {\n      try {\n        // Strip out the data url prefix if it\'s there\n        const base64Data = img.base64.replace(/^data:image\\/\\w+;base64,/, \"\");\n\n        const prompt = \"Analyze this coral photo. Determine a beautiful, catchy trade name for it \" +\n          \"(e.g., \'Dragon Soul Torch\', \'Sunset Montipora\', \'Neon Green Star Polyps\', \'Space Invader Pectinia\') \" +\n          \"and find its correct scientific name (at least the Genus level, species if identifiable). \" +\n          \"Provide care parameters including care level, lighting, flow, placement, and a vivid visual description.\";\n\n        const response = await retryWithBackoff(() => \n          ai.models.generateContent({\n            model: \"gemini-3.5-flash\",\n            contents: [\n              {\n                inlineData: {\n                  data: base64Data,\n                  mimeType: img.type || \"image/jpeg\",\n                },\n              },\n              {\n                text: prompt,\n              },\n            ],\n            config: {\n              responseMimeType: \"application/json\",\n              responseSchema: {\n                type: Type.OBJECT,\n                properties: {\n                  commonName: {\n                    type: Type.STRING,\n                    description: \"Creative, appealing, and colorful aquarium trade name (e.g. \'Rasta Zoanthid\').\",\n                  },\n                  scientificName: {\n                    type: Type.STRING,\n                    description: \"Scientific Genus and species name (e.g. \'Zoanthus sp.\').\",\n                  },\n                  careLevel: {\n                    type: Type.STRING,\n                    description: \"Aquarium care difficulty: Easy, Moderate, or Difficult.\",\n                  },\n                  lighting: {\n                    type: Type.STRING,\n                    description: \"Lighting intensity required: Low, Medium, or High.\",\n                  },\n                  waterFlow: {\n                    type: Type.STRING,\n                    description: \"Water movement/flow rate required: Low, Medium, or High.\",\n                  },\n                  placement: {\n                    type: Type.STRING,\n                    description: \"Recommended coral position in the tank (e.g., Low rockwork, Sandbed, Top reef, Any).\",\n                  },\n                  description: {\n                    type: Type.STRING,\n                    description: \"Vivid, attractive description highlighting the colors, textures, and growth form.\",\n                  },\n                },\n                required: [\n                  \"commonName\",\n                  \"scientificName\",\n                  \"careLevel\",\n                  \"lighting\",\n                  \"waterFlow\",\n                  \"placement\",\n                  \"description\",\n                ],\n              },\n            },\n          })\n        );"
    }
