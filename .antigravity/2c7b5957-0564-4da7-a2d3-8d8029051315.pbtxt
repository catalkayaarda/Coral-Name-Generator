    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "        const prompt = \"Analyze this coral photo. Determine a beautiful, catchy trade name for it \" +\n          \"(e.g., \'Dragon Soul Torch\', \'Sunset Montipora\', \'Neon Green Star Polyps\', \'Space Invader Pectinia\') \" +\n          \"and find its correct scientific name (at least the Genus level, species if identifiable). \" +\n          \"Provide care parameters including care level, lighting, flow, placement, and a vivid visual description.\";\n\n        const response = await retryWithBackoff(() => \n          ai.models.generateContent({\n            model: \"gemini-3.5-flash\",\n            contents: [\n              {\n                inlineData: {\n                  data: base64Data,\n                  mimeType: img.type || \"image/jpeg\",\n                },\n              },\n              {\n                text: prompt,\n              },\n            ],\n            config: {\n              responseMimeType: \"application/json\",\n              responseSchema: {\n                type: Type.OBJECT,\n                properties: {\n                  commonName: {\n                    type: Type.STRING,\n                    description: \"Creative, appealing, and colorful aquarium trade name (e.g. \'Rasta Zoanthid\').\",\n                  },\n                  scientificName: {\n                    type: Type.STRING,\n                    description: \"Scientific Genus and species name (e.g. \'Zoanthus sp.\').\",\n                  },\n                  careLevel: {\n                    type: Type.STRING,\n                    description: \"Aquarium care difficulty: Easy, Moderate, or Difficult.\",\n                  },\n                  lighting: {\n                    type: Type.STRING,\n                    description: \"Lighting intensity required: Low, Medium, or High.\",\n                  },\n                  waterFlow: {\n                    type: Type.STRING,\n                    description: \"Water movement/flow rate required: Low, Medium, or High.\",\n                  },\n                  placement: {\n                    type: Type.STRING,\n                    description: \"Recommended coral position in the tank (e.g., Low rockwork, Sandbed, Top reef, Any).\",\n                  },\n                  description: {\n                    type: Type.STRING,\n                    description: \"Vivid, attractive description highlighting the colors, textures, and growth form.\",\n                  },\n                },\n                required: [\n                  \"commonName\",\n                  \"scientificName\",\n                  \"careLevel\",\n                  \"lighting\",\n                  \"waterFlow\",\n                  \"placement\",\n                  \"description\",\n                ],\n              },\n            },\n          })\n        );\n\n        const textResult = response.text;\n        if (!textResult) {\n          throw new Error(\"No response text returned from Gemini\");\n        }\n\n        const data = JSON.parse(textResult);\n\n        results.push({\n          id: img.id,\n          fileName: img.name,\n          success: true,\n          imageBase64: img.base64,\n          mimeType: img.type,\n          ...data,\n        });\n      } catch (error: any) {\n        console.error(`Error analyzing image ${img.name}:`, error);\n        results.push({\n          id: img.id,\n          fileName: img.name,\n          success: false,\n          error: error.message || \"Failed to analyze image\",\n          imageBase64: img.base64,\n          mimeType: img.type,\n          commonName: \"Unknown Coral\",\n          scientificName: \"N/A\",\n          careLevel: \"Moderate\",\n          lighting: \"Medium\",\n          waterFlow: \"Medium\",\n          placement: \"Middle Rockwork\",\n          description: \"An attractive coral specimen (Gemini analysis failed to classify this image).\",\n        });\n      }"
